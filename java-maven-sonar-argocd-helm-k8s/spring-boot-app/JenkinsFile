pipeline {
    agent any

    tools {
        maven 'mvn'
    }
    environment {
        APP_PATH = "java-maven-sonar-argocd-helm-k8s/spring-boot-app"
        REGISTRY = "docker.io/gangalakunta"
        PROJECT_ID = 'project-820f02b7-4f02-4540-a71'
        CLUSTER_NAME = 'my-cluster'
        REGION = 'us-central1'
    }
    stages {
        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }
        stage('Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'git',
                    url: 'git@github.com:anilkumarreddy10/Jenkins-Zero-To-Hero.git'
            }
        }

        stage('Build') {
            steps {
                configFileProvider([
                    configFile(fileId: 'maven-settings', variable: 'SETTINGS')]) {
                    script {
                        if (params.PERFORM_MAVEN_RELEASE) {
                           sh """ cd ${APP_PATH} &&
                           mvn -B release:clean release:prepare release:perform \
                           -Dmaven.test.failure.ignore=true \
                           -s ${SETTINGS}
                           """
                        }
                        else{
                          sh 'mvn clean package'
                        }
                    }
                }
            }
        }
        stage('sonarqube') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh 'cd ${APP_PATH} && mvn sonar:sonar'
                }
            }
        }
        stage('docker') {
            steps {
                script {
                     def pom = readMavenPom file: 'java-maven-sonar-argocd-helm-k8s/spring-boot-app/pom.xml'
                      env.IMAGE_NAME = pom.artifactId
                      env.IMAGE_TAG  = pom.version
                }
                sh "cd ${APP_PATH} && docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ."
                sh " docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
        stage('push image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-cred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                   sh "echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin"
                   sh "docker push ${REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }
        stage('deploy to gke') {
            steps {
                withCredentials([
                     file(
                         credentialsId: 'gke-kubeconfig',
                         variable: 'KUBECONFIG'
                     )
                ]) {
                    sh "kubectl apply -f java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/ "
             }
        }
    }
}
}
